# Database — dev local: container quantua-db na porta 5436 (ver memória/README).
# Produção (Cloud SQL) conecta via unix socket; formato:
#   postgresql://user:pass@localhost/quantua?host=/cloudsql/quantua:southamerica-east1:quantua-db
DATABASE_URL="postgresql://user:password@localhost:5436/quantua"

# JWT
JWT_SECRET="troque-por-uma-string-aleatoria-longa"

# Anthropic (Claude)
ANTHROPIC_API_KEY="sk-ant-..."

# Storage — Google Cloud Storage via API S3-compatível (chaves HMAC de service
# account). Sem SPACES_KEY o storage cai no fallback local:base64 dentro do banco.
SPACES_ENDPOINT="https://storage.googleapis.com"
SPACES_REGION="auto"
SPACES_BUCKET="quantua-storage"
SPACES_KEY="chave-hmac-da-service-account"
SPACES_SECRET="secret-hmac"

# CORS — URL do frontend no ar
FRONTEND_URL="https://quantua.com.br"

# E-mail
# EMAIL_PROVIDER: "console" (default, loga no stdout) ou "resend".
EMAIL_PROVIDER="console"
# Necessário apenas quando EMAIL_PROVIDER="resend".
RESEND_API_KEY="re_..."
# Remetente. Para entregar a destinatários externos, o domínio precisa estar
# verificado no Resend. Default cai em onboarding@resend.dev no código.
EMAIL_FROM="Quantua <nao-responda@quantua.com.br>"
# Caixa(s) do time que recebem notificação de cada form de entrada (vírgula).
TEAM_INBOX_EMAIL="emerson@valoo.com.br,giovanni@valoo.com.br,rafael@manzoti.com,jorge@valoo.com.br"

# Jobs agendados (node-cron in-process)
JOBS_ENABLED="false"
JOBS_TZ="America/Sao_Paulo"
# Token para trigger manual de jobs via POST /admin/jobs/run/:jobName
ADMIN_TRIGGER_TOKEN=""

# Porta local para dev
PORT=3001
