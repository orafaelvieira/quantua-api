generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String     @id @default(uuid())
  email                   String     @unique
  name                    String
  passwordHash            String     @map("password_hash")
  workspaceType           String     @default("consultoria") @map("workspace_type")
  role                    String?
  professionalRegistration String?   @map("professional_registration")
  invitedAt               DateTime?  @map("invited_at")
  mustChangePassword      Boolean    @default(false) @map("must_change_password")
  createdAt               DateTime   @default(now()) @map("created_at")

  companies           Company[]
  analyses            Analysis[]
  dictionaries        AccountDictionary[]
  auditEvents         AuditEvent[]
  timeEntries         TimeEntry[]
  ownedEngagements    Engagement[]          @relation("EngagementRT")
  createdInvitations  ClientInvitation[]    @relation("InvitationCreator")
  engagementSignatures EngagementSignature[] @relation("Signer")

  @@index([role])
  @@map("users")
}

model AccountDictionary {
  id            String   @id @default(uuid())
  nomeOriginal  String   @map("nome_original")
  contaDestino  String   @map("conta_destino")
  grupoConta    String   @map("grupo_conta")
  tipo          String   @default("BP")
  userId        String?  @map("user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nomeOriginal, tipo, grupoConta, userId])
  @@index([userId])
  @@index([nomeOriginal])
  @@map("account_dictionaries")
}

model Company {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  razaoSocial  String   @map("razao_social")
  nomeFantasia String?  @map("nome_fantasia")
  cnpj         String?
  setor        String?
  porte        String?
  uf           String?
  status       String   @default("ativo")
  createdAt    DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses  Analysis[]
  documents Document[]

  @@map("companies")
}

model Analysis {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  userId            String   @map("user_id")
  nome              String
  periodo           String?
  tipo              String   @default("Completa")
  status            String   @default("Rascunho")
  confianca         Int?
  kind              String   @default("diagnostico")
  ibrType           String?  @map("ibr_type")
  sectorId          String?  @map("sector_id")
  reviewState       String   @default("draft") @map("review_state")
  resultado         Json?
  dadosEstruturados Json?    @map("dados_estruturados")
  documentChecklist Json?    @map("document_checklist")
  stcf              Json?
  scenarios         Json?
  options           Json?
  executiveSummary  Json?    @map("executive_summary")
  reviewMeta        Json?    @map("review_meta")
  signature         Json?
  questionnaire     Json?
  createdAt         DateTime @default(now()) @map("created_at")

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  documents   Document[]
  engagement  Engagement?
  auditEvents AuditEvent[]
  timeEntries TimeEntry[]

  @@map("analyses")
}

model Document {
  id             String   @id @default(uuid())
  analysisId     String   @map("analysis_id")
  companyId      String   @map("company_id")
  nome           String
  tipo           String
  competencia    String?
  moeda          String   @default("BRL")
  status         String   @default("Pendente")
  confianca      Int?
  storagePath    String?  @map("storage_path")
  hash           String?
  dadosExtraidos     Json?    @map("dados_extraidos")
  editadoManualmente Boolean  @default(false) @map("editado_manualmente")
  tamanho            String?
  createdAt      DateTime @default(now()) @map("created_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id])

  @@map("documents")
}

model Engagement {
  id                  String    @id @default(uuid())
  analysisId          String?   @unique @map("analysis_id")
  userId              String    @map("user_id")
  rtId                String?   @map("rt_id")
  companyName         String    @map("company_name")
  requestedBy         String    @map("requested_by")
  requestedByType     String    @map("requested_by_type")
  scope               String    @default("")
  state               String    @default("lead")
  deadline            DateTime?
  feeAmount           Float?    @map("fee_amount")
  feeCurrency         String    @default("BRL") @map("fee_currency")
  signedAt            DateTime? @map("signed_at")
  proposalUrl         String?   @map("proposal_url")
  contractUrls        Json?     @map("contract_urls")
  notes               String?
  letterAcceptedAt    DateTime? @map("letter_accepted_at")
  letterContentHash   String?   @map("letter_content_hash")
  letterVersion       String?   @map("letter_version")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  analysis    Analysis?             @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  rt          User?                 @relation("EngagementRT", fields: [rtId], references: [id], onDelete: SetNull)
  invitations ClientInvitation[]
  signatures  EngagementSignature[]

  @@index([userId])
  @@index([state])
  @@index([letterAcceptedAt])
  @@map("engagements")
}

model AuditEvent {
  id         String   @id @default(uuid())
  analysisId String?  @map("analysis_id")
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  entity     String
  entityId   String?  @map("entity_id")
  field      String
  before     Json?
  after      Json?
  source     String   @default("manual")
  reason     String?
  timestamp  DateTime @default(now())

  analysis Analysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])

  @@index([analysisId, timestamp])
  @@index([entity, entityId, timestamp])
  @@map("audit_events")
}

model TimeEntry {
  id         String   @id @default(uuid())
  analysisId String   @map("analysis_id")
  userId     String   @map("user_id")
  phase      String
  date       DateTime
  hours      Float
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([analysisId, date])
  @@index([userId])
  @@map("time_entries")
}

model Lead {
  id              String   @id @default(uuid())
  targetCompany   String   @map("target_company")
  reason          String
  debtVolume      String?  @map("debt_volume")
  desiredDeadline DateTime? @map("desired_deadline")
  contactName     String?  @map("contact_name")
  contactEmail    String   @map("contact_email")
  notes           String?
  status          String   @default("new")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("leads")
}

model ClientInvitation {
  id           String    @id @default(uuid())
  engagementId String    @map("engagement_id")
  email        String
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  status       String    @default("pending")
  createdById  String    @map("created_by_id")
  resendCount  Int       @default(0) @map("resend_count")
  lastSentAt   DateTime  @default(now()) @map("last_sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  createdBy  User       @relation("InvitationCreator", fields: [createdById], references: [id])

  @@index([engagementId, status])
  @@index([email])
  @@map("client_invitations")
}

model EngagementSignature {
  id            String   @id @default(uuid())
  engagementId  String   @map("engagement_id")
  signerType    String   @map("signer_type")
  signerUserId  String?  @map("signer_user_id")
  signerName    String   @map("signer_name")
  signerEmail   String   @map("signer_email")
  signerCpf     String?  @map("signer_cpf")
  contentHash   String   @map("content_hash")
  letterVersion String   @map("letter_version")
  signedAt      DateTime @default(now()) @map("signed_at")
  ipAddress     String   @map("ip_address")
  userAgent     String   @map("user_agent")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  signer     User?      @relation("Signer", fields: [signerUserId], references: [id])

  @@index([engagementId, signerType])
  @@map("engagement_signatures")
}
