generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String     @id @default(uuid())
  email                   String     @unique
  name                    String
  passwordHash            String     @map("password_hash")
  workspaceType           String     @default("consultoria") @map("workspace_type")
  role                    String?
  professionalRegistration String?   @map("professional_registration")
  invitedAt               DateTime?  @map("invited_at")
  mustChangePassword      Boolean    @default(false) @map("must_change_password")
  emailConfirmedAt        DateTime?  @map("email_confirmed_at")
  phone                   String?
  cargo                   String?
  timezone                String?    @default("America/Sao_Paulo")
  language                String?    @default("pt-BR")
  onboardedAt             DateTime?  @map("onboarded_at")
  workspaceId             String?    @map("workspace_id")
  createdAt               DateTime   @default(now()) @map("created_at")

  workspace           Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  companies           Company[]
  analyses            Analysis[]
  dictionaries        AccountDictionary[]
  auditEvents         AuditEvent[]
  timeEntries         TimeEntry[]
  allocations         Allocation[]
  ownedEngagements    Engagement[]          @relation("EngagementRT")
  createdInvitations  ClientInvitation[]    @relation("InvitationCreator")
  engagementSignatures EngagementSignature[] @relation("Signer")
  createdTeamInvites  TeamInvite[]          @relation("TeamInviteCreator")
  passwordResets      PasswordResetToken[]
  emailConfirmations  EmailConfirmationToken[]

  @@index([role])
  @@index([workspaceId])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("password_reset_tokens")
}

model EmailConfirmationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("email_confirmation_tokens")
}

model Workspace {
  id              String       @id @default(uuid())
  type            String       // "empresa" | "consultoria"
  cnpj            String?
  razaoSocial     String       @map("razao_social")
  nomeFantasia    String?      @map("nome_fantasia")
  setor           String?
  porte           String?      // micro | pequena | média | grande
  defaultCurrency String       @default("BRL") @map("default_currency")
  fiscalYearStart String       @default("january") @map("fiscal_year_start") // january | april | july
  auditLogsOn     Boolean      @default(true) @map("audit_logs_on")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  members User[]
  invites TeamInvite[]

  @@map("workspaces")
}

model TeamInvite {
  id           String    @id @default(uuid())
  workspaceId  String    @map("workspace_id")
  email        String
  role         String    // "operator" | "reviewer" | "partner"
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  invitedById  String    @map("invited_by_id")
  status       String    @default("pending") // pending | accepted | expired | revoked
  createdAt    DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("TeamInviteCreator", fields: [invitedById], references: [id])

  @@index([workspaceId, status])
  @@index([email])
  @@map("team_invites")
}

model AccountDictionary {
  id            String   @id @default(uuid())
  nomeOriginal  String   @map("nome_original")
  contaDestino  String   @map("conta_destino")
  grupoConta    String   @map("grupo_conta")
  tipo          String   @default("BP")
  userId        String?  @map("user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nomeOriginal, tipo, grupoConta, userId])
  @@index([userId])
  @@index([nomeOriginal])
  @@map("account_dictionaries")
}

model Company {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  razaoSocial  String   @map("razao_social")
  nomeFantasia String?  @map("nome_fantasia")
  cnpj         String?
  setor        String?
  porte        String?
  uf           String?
  status       String   @default("ativo")
  createdAt    DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses  Analysis[]
  documents Document[]

  @@map("companies")
}

model Analysis {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  userId            String   @map("user_id")
  nome              String
  periodo           String?
  tipo              String   @default("Completa")
  status            String   @default("Rascunho")
  confianca         Int?
  kind              String   @default("diagnostico")
  ibrType           String?  @map("ibr_type")
  sectorId          String?  @map("sector_id")
  reviewState       String   @default("draft") @map("review_state")
  resultado         Json?
  dadosEstruturados Json?    @map("dados_estruturados")
  documentChecklist Json?    @map("document_checklist")
  stcf              Json?
  scenarios         Json?
  options           Json?
  projections       Json?
  executiveSummary  Json?    @map("executive_summary")
  reviewMeta        Json?    @map("review_meta")
  signature         Json?
  questionnaire     Json?
  createdAt         DateTime @default(now()) @map("created_at")

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  documents   Document[]
  engagement  Engagement?
  auditEvents AuditEvent[]
  timeEntries TimeEntry[]
  allocations Allocation[]
  covenants   Covenant[]

  @@map("analyses")
}

model Document {
  id             String   @id @default(uuid())
  analysisId     String   @map("analysis_id")
  companyId      String   @map("company_id")
  nome           String
  tipo           String
  competencia    String?
  moeda          String   @default("BRL")
  status         String   @default("Pendente")
  confianca      Int?
  storagePath    String?  @map("storage_path")
  hash           String?
  dadosExtraidos     Json?    @map("dados_extraidos")
  editadoManualmente Boolean  @default(false) @map("editado_manualmente")
  tamanho            String?
  createdAt      DateTime @default(now()) @map("created_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id])

  @@map("documents")
}

model Engagement {
  id                  String    @id @default(uuid())
  analysisId          String?   @unique @map("analysis_id")
  userId              String    @map("user_id")
  rtId                String?   @map("rt_id")
  companyName         String    @map("company_name")
  requestedBy         String    @map("requested_by")
  requestedByType     String    @map("requested_by_type")
  scope               String    @default("")
  state               String    @default("lead")
  deadline            DateTime?
  feeAmount           Float?    @map("fee_amount")
  feeCurrency         String    @default("BRL") @map("fee_currency")
  signedAt            DateTime? @map("signed_at")
  proposalUrl         String?   @map("proposal_url")
  contractUrls        Json?     @map("contract_urls")
  notes               String?
  letterAcceptedAt    DateTime? @map("letter_accepted_at")
  letterContentHash   String?   @map("letter_content_hash")
  letterVersion       String?   @map("letter_version")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  analysis    Analysis?             @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  rt          User?                 @relation("EngagementRT", fields: [rtId], references: [id], onDelete: SetNull)
  invitations ClientInvitation[]
  signatures  EngagementSignature[]
  invoices    Invoice[]

  @@index([userId])
  @@index([state])
  @@index([letterAcceptedAt])
  @@map("engagements")
}

model AuditEvent {
  id         String   @id @default(uuid())
  analysisId String?  @map("analysis_id")
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  entity     String
  entityId   String?  @map("entity_id")
  field      String
  before     Json?
  after      Json?
  source     String   @default("manual")
  reason     String?
  timestamp  DateTime @default(now())

  analysis Analysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])

  @@index([analysisId, timestamp])
  @@index([entity, entityId, timestamp])
  @@map("audit_events")
}

model TimeEntry {
  id         String   @id @default(uuid())
  analysisId String   @map("analysis_id")
  userId     String   @map("user_id")
  phase      String
  date       DateTime
  hours      Float
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([analysisId, date])
  @@index([userId])
  @@map("time_entries")
}

model Lead {
  id              String   @id @default(uuid())
  targetCompany   String   @map("target_company")
  reason          String
  debtVolume      String?  @map("debt_volume")
  desiredDeadline DateTime? @map("desired_deadline")
  contactName     String?  @map("contact_name")
  contactEmail    String   @map("contact_email")
  notes           String?
  status          String   @default("new")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("leads")
}

model ClientInvitation {
  id           String    @id @default(uuid())
  engagementId String    @map("engagement_id")
  email        String
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  status       String    @default("pending")
  createdById  String    @map("created_by_id")
  resendCount  Int       @default(0) @map("resend_count")
  lastSentAt   DateTime  @default(now()) @map("last_sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  createdBy  User       @relation("InvitationCreator", fields: [createdById], references: [id])

  @@index([engagementId, status])
  @@index([email])
  @@map("client_invitations")
}

model EngagementSignature {
  id            String   @id @default(uuid())
  engagementId  String   @map("engagement_id")
  signerType    String   @map("signer_type")
  signerUserId  String?  @map("signer_user_id")
  signerName    String   @map("signer_name")
  signerEmail   String   @map("signer_email")
  signerCpf     String?  @map("signer_cpf")
  contentHash   String   @map("content_hash")
  letterVersion String   @map("letter_version")
  signedAt      DateTime @default(now()) @map("signed_at")
  ipAddress     String   @map("ip_address")
  userAgent     String   @map("user_agent")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  signer     User?      @relation("Signer", fields: [signerUserId], references: [id])

  @@index([engagementId, signerType])
  @@map("engagement_signatures")
}

model Invoice {
  id            String    @id @default(uuid())
  engagementId  String    @map("engagement_id")
  milestone     String    // "entry_50" | "final_50" | "other"
  amount        Float
  currency      String    @default("BRL")
  status        String    @default("draft") // draft | issued | paid | overdue | cancelled
  issuedAt      DateTime? @map("issued_at")
  dueDate       DateTime? @map("due_date")
  paidAt        DateTime? @map("paid_at")
  invoiceNumber String?   @map("invoice_number")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId, status])
  @@index([status, dueDate])
  @@map("invoices")
}

model Allocation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  analysisId   String   @map("analysis_id")
  phase        String   // engagement | collection | analysis | review | delivery
  plannedHours Float    @map("planned_hours")
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([analysisId, phase])
  @@map("allocations")
}

model Covenant {
  id          String   @id @default(uuid())
  analysisId  String   @map("analysis_id")
  name        String
  metric      String   // chave do indicador: netDebtEbitda, dscr, currentRatio, ebitdaMargin, minCash
  operator    String   // "<=" | ">=" | "<" | ">" | "=="
  threshold   Float
  periodicity String   @default("quarterly") // monthly | quarterly | annual
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("covenants")
}
