generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String     @id @default(uuid())
  email                   String     @unique
  name                    String
  passwordHash            String     @map("password_hash")
  workspaceType           String     @default("consultoria") @map("workspace_type")
  // Perfil de ICP auto-declarado no cadastro via páginas /para/* (contabilidade | bpo | cfo).
  // Opcional: nulo em cadastros que não vieram de uma página de perfil.
  partnerProfile          String?    @map("partner_profile")
  role                    String?
  // TIPO DE USUÁRIO (2026-07-17, fundação SaaS): "quantua" = equipe interna
  // (funcionário/diretor/sócio — o nível fino segue em `role`: operator/
  // reviewer/partner); "empresa" = responsável/funcionário do cliente (acessa a
  // empresa dele e as do GRUPO via Organizacao tipo "grupo"); "parceiro" =
  // contabilidade/advocacia etc. (acessa as empresas ATENDIDAS pela organização).
  // O portal legado continua marcado por role "client".
  tipoUsuario             String     @default("quantua") @map("tipo_usuario")
  professionalRegistration String?   @map("professional_registration")
  invitedAt               DateTime?  @map("invited_at")
  mustChangePassword      Boolean    @default(false) @map("must_change_password")
  emailConfirmedAt        DateTime?  @map("email_confirmed_at")
  phone                   String?
  cargo                   String?
  timezone                String?    @default("America/Sao_Paulo")
  language                String?    @default("pt-BR")
  onboardedAt             DateTime?  @map("onboarded_at")
  // Offboarding da equipe interna: preenchido = acesso REVOGADO (não loga, sessão
  // rejeitada). A conta e o histórico ficam; nada é apagado.
  desativadoEm            DateTime?  @map("desativado_em")
  workspaceId             String?    @map("workspace_id")
  createdAt               DateTime   @default(now()) @map("created_at")

  workspace           Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  companies           Company[]
  analyses            Analysis[]
  dictionaries        AccountDictionary[]
  auditEvents         AuditEvent[]
  timeEntries         TimeEntry[]
  allocations         Allocation[]
  ownedEngagements    Engagement[]          @relation("EngagementRT")
  createdInvitations  ClientInvitation[]    @relation("InvitationCreator")
  engagementSignatures EngagementSignature[] @relation("Signer")
  createdTeamInvites  TeamInvite[]          @relation("TeamInviteCreator")
  passwordResets      PasswordResetToken[]
  emailConfirmations  EmailConfirmationToken[]
  organizacoes        OrganizacaoMembro[]

  @@index([role])
  @@index([workspaceId])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("password_reset_tokens")
}

model EmailConfirmationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("email_confirmation_tokens")
}

model Workspace {
  id              String       @id @default(uuid())
  type            String       // "empresa" | "consultoria"
  cnpj            String?
  razaoSocial     String       @map("razao_social")
  nomeFantasia    String?      @map("nome_fantasia")
  setor           String?
  porte           String?      // micro | pequena | média | grande
  defaultCurrency String       @default("BRL") @map("default_currency")
  fiscalYearStart String       @default("january") @map("fiscal_year_start") // january | april | july
  auditLogsOn     Boolean      @default(true) @map("audit_logs_on")
  aiAnalysisModel String       @default("sonnet") @map("ai_analysis_model") // haiku | sonnet | opus — modelo de IA da análise (generateAnalysis)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  members User[]
  invites TeamInvite[]

  @@map("workspaces")
}

model TeamInvite {
  id           String    @id @default(uuid())
  workspaceId  String    @map("workspace_id")
  email        String
  role         String    // "operator" | "reviewer" | "partner"
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  invitedById  String    @map("invited_by_id")
  status       String    @default("pending") // pending | accepted | expired | revoked
  createdAt    DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("TeamInviteCreator", fields: [invitedById], references: [id])

  @@index([workspaceId, status])
  @@index([email])
  @@map("team_invites")
}

model AccountDictionary {
  id            String   @id @default(uuid())
  nomeOriginal  String   @map("nome_original")
  contaDestino  String   @map("conta_destino")
  grupoConta    String   @map("grupo_conta")
  tipo          String   @default("BP")
  userId        String?  @map("user_id")
  // Cascata de escopo (2026-07-17): companyId null + userId null = GLOBAL (seed);
  // companyId null + userId = workspace (legado/manual); companyId = EMPRESA
  // (autofeed do IBR — vale só para os IBRs daquela empresa, com userId = autor).
  companyId     String?  @map("company_id")
  // Entradas de EMPRESA: "pendente" | "aprovada" | "reprovada" | "local" — fila da
  // tela "Validação de contas" (aprovar promove ao dicionário global). Em QUALQUER
  // escopo: "cancelada" = fora da cascata dos folds (inclusão errada; reversível) —
  // globais canceladas não são herdadas por empresas novas.
  revisao       String?
  revisadoPor   String?   @map("revisado_por")
  revisadoEm    DateTime? @map("revisado_em")
  // Motivo da reprovação/cancelamento (obrigatório na reprovação da fila).
  revisaoMotivo String?   @map("revisao_motivo")
  // Caminho da conta no documento de origem ("Ativo Circulante > … > EMPRÉSTIMOS
  // A PESSOAS LIGADAS") — alimenta o detector de conta PARTICULAR e a promoção
  // "como regra de grupo" (promove o nome do grupo, nunca o nome do terceiro).
  grupoCaminho  String?   @map("grupo_caminho")
  // Varredura LGPD: entrada GLOBAL revisada por humano e mantida (falso positivo
  // do detector — ex.: "Banco do Brasil S/A") sai das varreduras seguintes.
  lgpdRevisadoEm  DateTime? @map("lgpd_revisado_em")
  lgpdRevisadoPor String?   @map("lgpd_revisado_por")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nomeOriginal, tipo, grupoConta, userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([nomeOriginal])
  @@map("account_dictionaries")
}

// Modelos padrão (BP/DRE) como DADO versionado — substituem os templates hardcoded.
// Globais (sem userId): um modelo BP e um DRE vigentes por vez (ativo=true). Versões
// anteriores ficam preservadas para auditoria e pinagem das análises.
model StandardModel {
  id        String   @id @default(uuid())
  tipo      String // "BP" | "DRE"
  versao    Int
  ativo     Boolean  @default(false)
  // companyId null = modelo GLOBAL; preenchido = modelo da EMPRESA (copy-on-write:
  // a 1ª versão da empresa nasce cópia do global vigente + edições; a empresa
  // passa a usar o seu; as demais seguem no global). Sequência de versão por escopo.
  companyId String?  @map("company_id")
  nota      String? // changelog da versão
  criadoPor String?  @map("criado_por")
  createdAt DateTime @default(now()) @map("created_at")

  linhas StandardModelLine[]

  @@unique([tipo, versao, companyId])
  @@index([tipo, ativo, companyId])
  @@map("standard_models")
}

// ── PARES CVM (dados abertos ITR/DFP) — pipeline automático de comparáveis ──
// Empresas listadas, demonstrativos por período e indicadores nas 3 VISÕES:
// TRI (trimestre isolado) · ANO (exercício fechado) · LTM (últimos 12 meses).
model CvmCompany {
  cnpj      String   @id // só dígitos
  cdCvm     String   @map("cd_cvm")
  denom     String
  ticker    String? // código emissor B3 (4 letras) — join exato CNPJ↔código via API de listadas
  // Taxonomia setorial oficial B3 (mesma semântica da PeerCompany):
  // classificacao = SETOR B3 · setor = SUBSETOR · subsetor = SEGMENTO
  classificacao String?
  setor         String?
  subsetor      String?
  pregao        String? // nome de pregão B3
  updatedAt DateTime @updatedAt @map("updated_at")

  periods    CvmPeriod[]
  indicators CvmIndicator[]

  @@map("cvm_companies")
}

model CvmPeriod {
  id     String   @id @default(uuid())
  cnpj   String
  dtFim  DateTime @map("dt_fim") // fim do trimestre/exercício
  origem String // "ITR" | "DFP"
  /// Contas já no MODELO QUANTUA (conta → R$): bp = snapshot no dtFim;
  /// dreTri = DRE DISCRETA do trimestre (no DFP = DRE do ano);
  /// dreYtd = DRE acumulada no ano; dfcYtd = FCO/FCI/FCF acumulados.
  bp     Json
  dreTri Json     @map("dre_tri")
  dreYtd Json     @map("dre_ytd")
  dfcYtd Json     @map("dfc_ytd")

  company CvmCompany @relation(fields: [cnpj], references: [cnpj], onDelete: Cascade)

  @@unique([cnpj, dtFim, origem])
  @@index([dtFim])
  @@map("cvm_periods")
}

model CvmIndicator {
  id    String   @id @default(uuid())
  cnpj  String
  dtFim DateTime @map("dt_fim")
  visao String // "TRI" | "ANO" | "LTM"
  nome  String
  valor Float?
  texto String? // indicadores textuais (Fleuriet)

  company CvmCompany @relation(fields: [cnpj], references: [cnpj])

  @@unique([cnpj, dtFim, visao, nome])
  @@index([dtFim, visao, nome])
  @@map("cvm_indicators")
}

/// Aviso de sistema no Inbox (ex.: "base CVM atualizada — sincronize os pares").
/// `chave` deduplica (mesmo arquivo+versão nunca avisa duas vezes).
model SystemNotice {
  id        String   @id @default(uuid())
  tipo      String // "cvm_update"
  titulo    String
  corpo     String?
  href      String?
  chave     String?  @unique
  lida      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([lida, createdAt])
  @@map("system_notices")
}

/// Estado de sincronização por arquivo da CVM (ETag/Last-Modified) — o cron compara
/// com o publicado e avisa no Inbox quando houver versão nova.
model CvmSyncState {
  id           String   @id @default(uuid())
  arquivo      String   @unique // ex.: "itr_2026" | "dfp_2025"
  etag         String?
  lastModified String?  @map("last_modified")
  processadoEm DateTime @map("processado_em")
  empresas     Int      @default(0)
  periodos     Int      @default(0)

  @@map("cvm_sync_state")
}

// Configuração dos INDICADORES — a tela "Indicadores" do menu edita esta tabela.
// Sistema (sistema=true): os 36+ canônicos do código — NÃO deletáveis (IA/estágio/pares
// dependem deles); podem ter semáforo editado e exibição desativada (ativo=false, o
// motor CONTINUA calculando). Personalizados (sistema=false): fórmula estruturada
// numerador/denominador como somas de linhas do modelo padrão — aditivos, deletáveis.
model IndicatorConfig {
  id       String  @id @default(uuid())
  nome     String  @unique
  sistema  Boolean @default(false)
  ativo    Boolean @default(true) // exibição (aba/PDF/CSV); cálculo do sistema não para
  grupo    String
  tipoDado String  @default("Índice") // R$ | % | Índice | Dias | Texto
  formula  String? // texto exibido (tooltip/PDF)

  // Fórmula estruturada (SÓ personalizados): (Σ numerador) / (Σ denominador) × multiplicador
  numerador     Json? // Array<{ origem: "BP"|"DRE", conta: string, sinal: 1|-1, abs?: boolean }>
  denominador   Json? // idem; ausente = só numerador
  multiplicador Float? // ex.: 365 para prazos

  // Semáforo (opcional): direção "menor_ruim" (crítico se v < limiar) | "maior_ruim" (v > limiar)
  semDirecao String? @map("sem_direcao")
  semCritico Float?  @map("sem_critico")
  semAtencao Float?  @map("sem_atencao")

  ordem     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([grupo, ordem])
  @@map("indicator_configs")
}

// Versionamento do dicionário (controle INTERNO — não aparece em relatórios). O dicionário
// é uma tabela viva/autoalimentada, não um template; então "versão" = contador monotônico
// global + changelog (cada mudança = uma linha). A análise carimba a versão usada no fold.
model DictionaryVersion {
  id           String   @id @default(uuid())
  versao       Int      @unique // monotônico global
  acao         String // "add" | "edit" | "delete" | "classify"
  fonte        String   @default("manual") // "manual" | "autofeed"
  nomeOriginal String?  @map("nome_original")
  contaDestino String?  @map("conta_destino")
  grupoConta   String?  @map("grupo_conta")
  tipo         String?
  nota         String? // resumo (ex.: importação oficial em lote)
  criadoPor    String?  @map("criado_por")
  analysisId   String?  @map("analysis_id") // IBR que originou (autofeed via /classify)
  companyId    String?  @map("company_id") // empresa dona da entrada (cascata por empresa)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([versao])
  @@index([createdAt])
  @@map("dictionary_versions")
}

model StandardModelLine {
  id      String  @id @default(uuid())
  modelId String  @map("model_id")
  codigo  String // chave ESTÁVEL (cascata/indicadores referenciam por código, não nome)
  nome    String
  grupo   String  @default("") // classificacao do BP (AT/AC/AF/AO/ANC/PT/PC/PF/PNC/PL); "" na DRE
  ordem   Int
  tipo    String  @default("input") // "input" | "subtotal" | "total"
  nivel   Int     @default(2)
  sinal   Int? // convenção de sinal para inputs (+1/-1); null = neutro/subtotal
  descricao String? // guia "o que entra / o que NÃO entra" — exibido nos dropdowns de classificação

  model StandardModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("standard_model_lines")
}

model Company {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  razaoSocial  String   @map("razao_social")
  nomeFantasia String?  @map("nome_fantasia")
  cnpj         String?
  setor        String?
  porte        String?
  uf           String?
  status       String   @default("ativo")
  // ── Dados da Receita Federal (consulta CNPJ · BrasilAPI) ──
  // Campos promovidos = os que a UI/análise usam direto; cnpjData guarda a
  // RESPOSTA COMPLETA da consulta (nada se perde — QSA, endereço, CNAEs 2os…).
  municipio           String?
  cnae                String? // código CNAE principal (7 dígitos)
  cnaeDescricao       String? @map("cnae_descricao")
  naturezaJuridica    String? @map("natureza_juridica")
  dataInicioAtividade String? @map("data_inicio_atividade") // AAAA-MM-DD
  situacaoCadastral   String? @map("situacao_cadastral") // ATIVA/SUSPENSA/BAIXADA…
  capitalSocial       Float?  @map("capital_social")
  regimeTributario    String? @map("regime_tributario") // MEI/Simples Nacional/Lucro Presumido/Lucro Real
  cnpjData            Json?   @map("cnpj_data")
  createdAt    DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  // ── WORKSPACE FP&A (W2, 2026-07-20) ──
  /// REGIME DE FECHAMENTO da empresa (decisão de 20/07/2026): "contabil" = o
  /// balancete manda no número oficial (gerencial é prévia); "gerencial" = as
  /// planilhas mapeadas mandam e o balancete concilia retroativamente. Define
  /// QUANDO o mês fecha — o gate da Apresentação de resultados.
  regimeFechamento String @default("contabil") @map("regime_fechamento")

  analyses  Analysis[]
  documents Document[]
  organizacoes OrganizacaoEmpresa[]
  produtos  ProdutoEmpresa[]
  periodos  PeriodoEmpresa[]

  @@map("companies")
}

// ── ACESSO POR ORGANIZAÇÃO (2026-07-17) — fundação do modelo SaaS ────────────
// Três tipos de usuário externo à equipe Quantua:
//   GRUPO (tipo "grupo"): o grupo econômico do cliente — holding + investidas/
//     filiais. Usuário "empresa" membro do grupo acessa TODAS as empresas dele.
//   PARCEIRO (tipo "parceiro"): contabilidade/advocacia/consultoria — os membros
//     acessam as empresas ATENDIDAS (uma ou várias, de clientes distintos).
// A equipe Quantua NÃO usa Organizacao (escopo por workspace, como sempre).
// FUNDAÇÃO INERTE: as tabelas existem e a resolução de escopo já as entende;
// nenhuma rota muda de comportamento até a Fase 2 (queries por scopeCompanyIds).
model Organizacao {
  id        String   @id @default(uuid())
  nome      String
  tipo      String // "grupo" | "parceiro"
  subtipo   String? // parceiro: "contabilidade" | "advocacia" | "consultoria" | ...
  cnpj      String?
  // CICLO DE VIDA (2026-07-17): o status é DERIVADO destes campos (nunca gravado).
  //   dataFim no passado         → "cancelado"  (sem acesso)
  //   dataInicio no futuro       → "agendado"   (sem acesso ainda)
  //   suspenso = true            → "suspenso"   (SOMENTE CONSULTA — inadimplência)
  //   caso contrário             → "ativo"      (acesso pleno)
  // dataFim >= dataInicio é validado na rota. Substitui a exclusão: a organização
  // nunca some (trilha/compliance), só muda de status.
  dataInicio DateTime? @map("data_inicio")
  dataFim    DateTime? @map("data_fim")
  suspenso   Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")

  membros  OrganizacaoMembro[]
  empresas OrganizacaoEmpresa[]
  convites OrganizacaoConvite[]

  @@map("organizacoes")
}

model OrganizacaoMembro {
  id            String   @id @default(uuid())
  organizacaoId String   @map("organizacao_id")
  userId        String   @map("user_id")
  papel         String   @default("membro") // "gestor" (concede acessos) | "membro"
  // Vigência do ACESSO do membro (saída da organização = preencher dataFim).
  // Fora de [dataInicio, dataFim] o membro não recebe empresa nenhuma no escopo.
  dataInicio    DateTime? @map("data_inicio")
  dataFim       DateTime? @map("data_fim")
  createdAt     DateTime @default(now()) @map("created_at")

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizacaoId, userId])
  @@index([userId])
  @@map("organizacao_membros")
}

// Convite de membro para uma organização (grupo/parceiro) — magic link de uso
// único, mesmo padrão do TeamInvite. O aceite cria o User com tipoUsuario
// derivado do tipo da organização e o vincula como membro.
model OrganizacaoConvite {
  id            String    @id @default(uuid())
  organizacaoId String    @map("organizacao_id")
  email         String
  papel         String    @default("membro") // "gestor" | "membro"
  tokenHash     String    @unique @map("token_hash")
  expiresAt     DateTime  @map("expires_at")
  acceptedAt    DateTime? @map("accepted_at")
  invitedById   String    @map("invited_by_id")
  status        String    @default("pending") // pending | accepted | expired | revoked
  createdAt     DateTime  @default(now()) @map("created_at")

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)

  @@index([organizacaoId])
  @@map("organizacao_convites")
}

model OrganizacaoEmpresa {
  id            String   @id @default(uuid())
  organizacaoId String   @map("organizacao_id")
  companyId     String   @map("company_id")
  vinculo       String   @default("atendida") // "dona" (grupo econômico) | "atendida" (parceiro)
  papelGrupo    String?  @map("papel_grupo") // grupo: "holding" | "investida" | "filial"
  createdAt     DateTime @default(now()) @map("created_at")

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([organizacaoId, companyId])
  @@index([companyId])
  @@map("organizacao_empresas")
}

model Analysis {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  userId            String   @map("user_id")
  nome              String
  periodo           String?
  tipo              String   @default("Completa")
  status            String   @default("Rascunho")
  confianca         Int?
  /// kind (legado, até v2.1): "diagnostico" | "ibr" — granularidade só de tipo de produto.
  /// Mantido para retrocompat com análises pré-pivot B2B-3.
  kind              String   @default("diagnostico")
  /// TESTE (higienização, 21/07/2026): IBR de teste/descartado fica FORA de
  /// qualquer listagem e relatório futuro (a listagem padrão exclui; produtos e
  /// portal nunca o veem). Marcação explícita, com trilha — os dados ficam na
  /// base como evidência, mas invisíveis no dia a dia.
  ehTeste           Boolean  @default(false) @map("eh_teste")
  /// MOTIVO DA VERSÃO (21/07/2026): por que esta versão existe ("refeita após
  /// substituição do balancete de mai/26"). Preenchido pelo "Nova versão…" —
  /// obrigatório lá; null nas versões originais. Aparece no envelope e no PDF.
  motivoVersao      String?  @map("motivo_versao")
  /// mode (pivot B2B-3, v3): "recurring" | "ibr" — modalidade de operação.
  /// "recurring": diagnóstico mensal/trimestral do BPO sobre cliente da carteira (default).
  /// "ibr": modalidade premium contratada à parte para momentos críticos (valuation,
  /// readiness de crédito, M&A, restructuring). Quando "ibr", o Engagement é obrigatório.
  mode              String?  @map("mode")
  ibrType           String?  @map("ibr_type")
  sectorId          String?  @map("sector_id")
  /// Setor CONFIRMADO pelo analista (escolha explícita no wizard/Escopo ou clique na
  /// proposta do classificador). Sem confirmação, a GERAÇÃO da análise fica bloqueada
  /// (setor errado envenena pares/semáforo/valor na mesa). Análises legadas já geradas
  /// contam como confirmadas (regra no código — sem backfill).
  setorConfirmado   Boolean  @default(false) @map("setor_confirmado")
  /// Proposta do CLASSIFICADOR DE SETOR (determinístico, zero IA): ranking de aderência
  /// dos números da empresa às distribuições de cada subsetor da base CVM.
  setorProposta     Json?    @map("setor_proposta")
  /// Texto livre do setor/subsetor quando o analista escolhe "Outros" no picker
  /// (atividade que não encaixa na taxonomia B3). Alimenta o setorText do
  /// resolvedor de premissas como último recurso.
  sectorCustom      String?  @map("sector_custom")
  reviewState       String   @default("draft") @map("review_state")
  resultado         Json?
  dadosEstruturados Json?    @map("dados_estruturados")
  /// Configuração de INDICADORES deste IBR ({ calibrado, pares, rows }): réplica editável
  /// do catálogo padrão, com semáforo pré-calibrado pelos PARES do setor (quartis CVM).
  /// Null = IBR usa o catálogo global (comportamento anterior). Coluna própria (não em
  /// dadosEstruturados) para SOBREVIVER ao "Reprocessar tudo", que reconstrói os dados.
  indicadorConfig   Json?    @map("indicador_config")
  documentChecklist Json?    @map("document_checklist")
  stcf              Json?
  scenarios         Json?
  options           Json?
  projections       Json?
  executiveSummary  Json?    @map("executive_summary")
  reviewMeta        Json?    @map("review_meta")
  signature         Json?
  questionnaire     Json?
  /// DORES declaradas pelo dono/gestão (entrevista): Array<{categoria, descricao,
  /// severidade}>. Fonte [5] do prompt da análise — confronto declarado×observado
  /// gera confrontoDores e pontosCegos (número ruim SEM dor declarada).
  dores             Json?
  createdAt         DateTime @default(now()) @map("created_at")

  /// Próxima revisão agendada (apenas mode=recurring). Cron diário varre
  /// análises com `nextReviewAt <= now+14d` e dispara email ao RT/operator.
  /// Calculado em POST /analyses como createdAt + reviewCadenceDays.
  /// RT pode adiar via POST /analyses/:id/snooze-review (+7d).
  nextReviewAt          DateTime? @map("next_review_at")
  /// Última vez que o cron disparou notificação. Usado pra idempotência —
  /// pula registros notificados < 1d antes do próximo review.
  lastReviewNotifiedAt  DateTime? @map("last_review_notified_at")
  /// Cadência em dias entre revisões recorrentes. Default 30 (mensal).
  reviewCadenceDays     Int       @default(30) @map("review_cadence_days")

  // ── WORKSPACE FP&A (W1, 2026-07-20) — campos ADITIVOS e anuláveis ──
  /// Envelope de produto ao qual este IBR pertence como VERSÃO (declarado
  /// pelo analista no workspace; null = registro solto, comportamento de sempre).
  produtoId     String? @map("produto_id")
  /// Nº da versão dentro do envelope (monotônico; atribuído ao declarar).
  produtoVersao Int?    @map("produto_versao")

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  /// SetNull: sumir o envelope jamais pode derrubar o IBR (zero retrocesso).
  produto     ProdutoEmpresa? @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  documents   Document[]
  engagement  Engagement?
  auditEvents AuditEvent[]
  versions    AnalysisVersion[]
  timeEntries TimeEntry[]
  allocations Allocation[]
  covenants   Covenant[]

  @@index([mode, nextReviewAt])
  @@index([produtoId])
  @@map("analyses")
}

model Document {
  id             String   @id @default(uuid())
  /// DATA ROOM ÚNICA (Parte 12 do plano, 2026-07-20): anulável — documento SEM
  /// análise é documento do POOL da empresa (entrada pelo workspace, antes de
  /// qualquer IBR existir). Os fluxos do IBR seguem preenchendo sempre; docs de
  /// pool são invisíveis às telas do IBR por construção (todo filtro é por
  /// analysisId). Fase B: o IBR FIXA documentos do pool em linha própria.
  analysisId     String?  @map("analysis_id")
  companyId      String   @map("company_id")
  nome           String
  tipo           String
  competencia    String?
  moeda          String   @default("BRL")
  status         String   @default("Pendente")
  confianca      Int?
  storagePath    String?  @map("storage_path")
  hash           String?
  dadosExtraidos     Json?    @map("dados_extraidos")
  editadoManualmente Boolean  @default(false) @map("editado_manualmente")
  /// EXTRAÇÃO HERDADA (caso misto da herança, 2026-07-21): dadosExtraidos foi
  /// COPIADO da versão anterior do IBR porque o arquivo é idêntico (hash) —
  /// o /process reusa esse cache em vez de re-baixar e re-parsear (mesma
  /// mecânica do editadoManualmente). Substituir o documento zera a marca
  /// (linha nova). Reprocessar com { forcarReextracao: true } ignora a marca.
  extracaoHerdada    Boolean  @default(false) @map("extracao_herdada")
  tamanho            String?
  // VERSIONAMENTO (política 2026-07-15): documento nunca é deletado depois de
  // processado — é SUBSTITUÍDO. A versão antiga fica com status "Substituído",
  // arquivo preservado no storage (evidência) e o ponteiro para a sucessora.
  versao              Int      @default(1)
  substituidoPorId    String?  @map("substituido_por_id")
  motivoSubstituicao  String?  @map("motivo_substituicao")
  /// FIXAÇÃO (Fase B da Data room única): esta linha é a evidência de um IBR
  /// criada a partir de um documento do POOL — aponta para a linha de origem.
  /// A linha do pool é imutável (substituir cria linha NOVA), então a versao
  /// dela É a proveniência congelada ("usa Balancete jun/26 v3"); pool com
  /// substituidoPorId preenchido = "insumo desatualizado" nos IBRs que a fixaram.
  fixadoDeId          String?  @map("fixado_de_id")
  createdAt      DateTime @default(now()) @map("created_at")

  /// Opcional (pool). Quando presente, o cascade continua: apagar a análise
  /// apaga OS DOCUMENTOS DELA — docs de pool sobrevivem (são fato da empresa)
  /// e caem só com a empresa (cascade abaixo).
  analysis Analysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  // Cascade TAMBÉM por empresa: sem ele o RESTRICT dispara IMEDIATO no
  // Postgres e excluir empresa com documentos falha — mesmo que a cascata
  // das análises fosse apagar esses documentos logo em seguida.
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // SetNull (não Restrict): no cascade da empresa a ordem de exclusão entre
  // pool e fixações não é garantida — Restrict faria a exclusão da empresa
  // falhar. A guarda de negócio (não remover pool fixado) fica na rota.
  fixadoDe Document?  @relation("FixacaoPool", fields: [fixadoDeId], references: [id], onDelete: SetNull)
  fixacoes Document[] @relation("FixacaoPool")

  @@map("documents")
}

// HASH DE VERSÃO por extração (política 2026-07-15): cada processamento grava a
// PROVENIÊNCIA completa dos insumos usados — documentos (hash sha256 + versão),
// dicionário de contas e modelos padrão de BP/DRE — consultável por análise.
// Produtos derivados (Valuation/BP/Orçamento) carimbam o hash da versão que os
// semeou; divergência do hash atual = histórico desatualizado.
model AnalysisVersion {
  id         String   @id @default(uuid())
  analysisId String   @map("analysis_id")
  hash       String
  motivo     String   @default("extração")
  insumos    Json
  criadoEm   DateTime @default(now()) @map("criado_em")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId, criadoEm])
  @@map("analysis_versions")
}

model Engagement {
  id                  String    @id @default(uuid())
  analysisId          String?   @unique @map("analysis_id")
  userId              String    @map("user_id")
  rtId                String?   @map("rt_id")
  companyName         String    @map("company_name")
  requestedBy         String    @map("requested_by")
  requestedByType     String    @map("requested_by_type")
  scope               String    @default("")
  state               String    @default("lead")
  deadline            DateTime?
  feeAmount           Float?    @map("fee_amount")
  feeCurrency         String    @default("BRL") @map("fee_currency")
  signedAt            DateTime? @map("signed_at")
  proposalUrl         String?   @map("proposal_url")
  contractUrls        Json?     @map("contract_urls")
  notes               String?
  letterAcceptedAt    DateTime? @map("letter_accepted_at")
  letterContentHash   String?   @map("letter_content_hash")
  letterVersion       String?   @map("letter_version")
  /// PDF gerado pelo endpoint generate-proposal (fricção #8).
  /// `proposalUrl` continua válido pra retrocompat (browser-print fallback),
  /// mas o caminho preferido é PDF binário em Spaces servido via signed URL.
  proposalPdfStoragePath String?   @map("proposal_pdf_storage_path")
  proposalPdfHash        String?   @map("proposal_pdf_hash")
  proposalGeneratedAt    DateTime? @map("proposal_generated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  analysis    Analysis?             @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  rt          User?                 @relation("EngagementRT", fields: [rtId], references: [id], onDelete: SetNull)
  invitations ClientInvitation[]
  signatures  EngagementSignature[]
  invoices    Invoice[]

  @@index([userId])
  @@index([state])
  @@index([letterAcceptedAt])
  @@map("engagements")
}

model AuditEvent {
  id         String   @id @default(uuid())
  analysisId String?  @map("analysis_id")
  userId     String   @map("user_id")
  userName   String   @map("user_name")
  entity     String
  entityId   String?  @map("entity_id")
  field      String
  before     Json?
  after      Json?
  source     String   @default("manual")
  reason     String?
  timestamp  DateTime @default(now())

  analysis Analysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])

  @@index([analysisId, timestamp])
  @@index([entity, entityId, timestamp])
  @@map("audit_events")
}

model TimeEntry {
  id         String   @id @default(uuid())
  analysisId String   @map("analysis_id")
  userId     String   @map("user_id")
  phase      String
  date       DateTime
  hours      Float
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([analysisId, date])
  @@index([userId])
  @@map("time_entries")
}

/// Lead — captura de prospects.
///
/// Histórico:
/// - v1 (até 2026-05-22): IBR pontual lado credor. Campos: targetCompany, reason
///   (enum credor: credit_approval/judicial_recovery/refinancing/due_diligence/monitoring),
///   debtVolume, desiredDeadline.
/// - v2 (2026-05-22+, pivot B2B-3): qualificação de design partner. targetCompany
///   carrega o nome da FIRMA (parceiro BPO), reason carrega firmType
///   (contabilidade_consultiva/bpo_financeiro/cfoaas/contabilidade_tradicional).
///   Campos nominais novos (firmType, portfolioSize, etc.) são opcionais — frontend
///   ainda envia parte dos dados em notes markdown legível por enquanto.
///
/// debtVolume e desiredDeadline ficam para retrocompat com leads históricos.
model Lead {
  id                     String   @id @default(uuid())
  targetCompany          String   @map("target_company")
  reason                 String
  debtVolume             String?  @map("debt_volume")
  desiredDeadline        DateTime? @map("desired_deadline")
  contactName            String?  @map("contact_name")
  contactEmail           String   @map("contact_email")
  notes                  String?
  status                 String   @default("new")
  // Pivot B2B-3: campos nominais para qualificação de design partner (opcionais).
  contactRole            String?  @map("contact_role")
  contactPhone           String?  @map("contact_phone")
  firmType               String?  @map("firm_type")
  portfolioSize          String?  @map("portfolio_size")
  portfolioMidMarketPct  String?  @map("portfolio_midmarket_pct")
  teamSize               String?  @map("team_size")
  consultingPricingModel String?  @map("consulting_pricing_model")
  weeklyAvailability     Boolean? @map("weekly_availability")
  createdAt              DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([firmType])
  @@map("leads")
}

model ClientInvitation {
  id           String    @id @default(uuid())
  engagementId String    @map("engagement_id")
  email        String
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  status       String    @default("pending")
  createdById  String    @map("created_by_id")
  resendCount  Int       @default(0) @map("resend_count")
  lastSentAt   DateTime  @default(now()) @map("last_sent_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  createdBy  User       @relation("InvitationCreator", fields: [createdById], references: [id])

  @@index([engagementId, status])
  @@index([email])
  @@map("client_invitations")
}

model EngagementSignature {
  id            String   @id @default(uuid())
  engagementId  String   @map("engagement_id")
  signerType    String   @map("signer_type")
  signerUserId  String?  @map("signer_user_id")
  signerName    String   @map("signer_name")
  signerEmail   String   @map("signer_email")
  signerCpf     String?  @map("signer_cpf")
  contentHash   String   @map("content_hash")
  letterVersion String   @map("letter_version")
  signedAt      DateTime @default(now()) @map("signed_at")
  ipAddress     String   @map("ip_address")
  userAgent     String   @map("user_agent")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  signer     User?      @relation("Signer", fields: [signerUserId], references: [id])

  @@index([engagementId, signerType])
  @@map("engagement_signatures")
}

model Invoice {
  id            String    @id @default(uuid())
  engagementId  String    @map("engagement_id")
  milestone     String    // "entry_50" | "final_50" | "other"
  amount        Float
  currency      String    @default("BRL")
  status        String    @default("draft") // draft | issued | paid | overdue | cancelled
  issuedAt      DateTime? @map("issued_at")
  dueDate       DateTime? @map("due_date")
  paidAt        DateTime? @map("paid_at")
  invoiceNumber String?   @map("invoice_number")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId, status])
  @@index([status, dueDate])
  @@map("invoices")
}

model Allocation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  analysisId   String   @map("analysis_id")
  phase        String   // engagement | collection | analysis | review | delivery
  plannedHours Float    @map("planned_hours")
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([analysisId, phase])
  @@map("allocations")
}

/// Registro de execuções de jobs schedulados (cron in-process).
/// Serve para: (1) observabilidade — qual job rodou quando e com que
/// resultado; (2) lock leve — bloqueia execução concorrente (e prepara
/// multi-instance no futuro); (3) rescue — runs travadas > 1h viram
/// status=failed para liberar próximo tick.
model JobRun {
  id         String    @id @default(uuid())
  jobName    String    @map("job_name")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  status     String    @default("running") // running | success | failed
  meta       Json?

  @@index([jobName, startedAt])
  @@index([status, startedAt])
  @@map("job_runs")
}

model Covenant {
  id          String   @id @default(uuid())
  analysisId  String   @map("analysis_id")
  name        String
  metric      String   // chave do indicador: netDebtEbitda, dscr, currentRatio, ebitdaMargin, minCash
  operator    String   // "<=" | ">=" | "<" | ">" | "=="
  threshold   Float
  periodicity String   @default("quarterly") // monthly | quarterly | annual
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@map("covenants")
}

/// Catálogo canônico de setores Quantua.
/// `code` é string semântica (não UUID) pra debug — ex.: "industria_textil", "varejo".
/// Hierarquia opcional via parentCode (ex.: industria_textil → industria).
/// Source-of-truth pra dropdown do wizard e pra `Analysis.sectorId`.
model Sector {
  code              String   @id
  name              String
  parentCode        String?  @map("parent_code")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  parent            Sector?            @relation("SectorHierarchy", fields: [parentCode], references: [code])
  children          Sector[]           @relation("SectorHierarchy")
  benchmarks        SectorBenchmark[]
  cnaeMappings      CnaeMapping[]
  damodaranMappings DamodaranMapping[]

  @@index([parentCode])
  @@map("sectors")
}

/// Benchmarks setoriais — EAV (entity-attribute-value) append-only.
/// Nunca UPDATE; sempre INSERT de nova linha quando a fonte atualiza.
/// `metric` exemplos: "receita_growth", "margem_bruta_p50", "dso_p50",
/// "capex_pct_receita", "custo_medio_divida".
/// `source`: "manual_curation" | "damodaran" | "ibge_pia" | "bcb_sgs".
model SectorBenchmark {
  id           String   @id @default(uuid())
  sectorCode   String   @map("sector_code")
  year         Int
  source       String
  metric       String
  value        Float
  percentile   Int?
  unit         String
  sampleSize   Int?     @map("sample_size")
  rawSourceUrl String?  @map("raw_source_url")
  fetchedAt    DateTime @map("fetched_at")
  notes        String?

  sector       Sector   @relation(fields: [sectorCode], references: [code])

  @@unique([sectorCode, year, source, metric, percentile])
  @@index([sectorCode, year])
  @@index([source, fetchedAt])
  @@map("sector_benchmarks")
}

/// Mapeamento CNAE (Brasil) → setor Quantua.
/// CNAE sem ponto, ex.: "10112" (não "10.11-2").
/// Granularidade 2-3 dígitos pra MVP; 5-dig é overkill.
model CnaeMapping {
  cnae        String   @id
  sectorCode  String   @map("sector_code")
  description String?
  confidence  String   @default("high")
  reviewedAt  DateTime @map("reviewed_at")

  sector      Sector   @relation(fields: [sectorCode], references: [code])

  @@index([sectorCode])
  @@map("cnae_mappings")
}

/// Mapeamento Damodaran (NYU Stern) industries → setor Quantua.
/// Ex.: "Apparel" → "industria_textil".
model DamodaranMapping {
  damodaranIndustry String   @id @map("damodaran_industry")
  sectorCode        String   @map("sector_code")
  notes             String?

  sector            Sector   @relation(fields: [sectorCode], references: [code])

  @@index([sectorCode])
  @@map("damodaran_mappings")
}

/// Base de PARES — empresas listadas na B3 (data-base 31/12/25). Catálogo + linhas
/// (BP/DRE brutos + indicadores) por ano. Fonte: base_bovespa.xlsx. Usada p/ comparação
/// setorial (percentil vs pares) e semáforo dinâmico. Taxonomia B3: Classificação › Setor › Subsetor.
model PeerCompany {
  papel         String   @id // ticker, ex.: "AERI3"
  nome          String
  classificacao String // nível 1 B3 (ex.: "Bens Industriais")
  setor         String // nível 2 B3 (ex.: "Máquinas e Equipamentos")
  subsetor      String? // nível 3 B3
  createdAt     DateTime @default(now()) @map("created_at")

  lines PeerLine[]

  @@index([classificacao])
  @@index([setor])
  @@index([subsetor])
  @@map("peer_companies")
}

model PeerLine {
  id        String @id @default(uuid())
  papel     String
  documento String // "BP" | "DRE" | "INDICADOR"
  conta     String // nome da conta/indicador na base B3
  year      Int
  value     Float

  company PeerCompany @relation(fields: [papel], references: [papel], onDelete: Cascade)

  @@unique([papel, documento, conta, year])
  @@index([documento, conta, year])
  @@map("peer_lines")
}

/// Marcador genérico de seed idempotente: guarda o hash do arquivo aplicado por chave,
/// p/ o importador pular o trabalho quando o arquivo não mudou (boot rápido).
model SeedMarker {
  key       String   @id
  hash      String
  appliedAt DateTime @updatedAt @map("applied_at")

  @@map("seed_markers")
}

/// ── MODELOS FINANCEIROS (produto Projeções/Orçamento/Valuation) ──────────────
/// Modelo financeiro VIVO de uma empresa — esteira separada do IBR (F1 do
/// PLANO_VALUATION_ORCAMENTO.md). Motor mensal; blocos modulares; cenários.
model FinancialModel {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  userId         String   @map("user_id")
  nome           String
  /// "valuation" | "orcamento" | "ambos" — decide os blocos default do wizard
  objetivo       String   @default("ambos")
  /// 1º mês do horizonte, "YYYY-MM" (motor é mensal SEMPRE)
  mesInicial     String   @map("mes_inicial")
  horizonteMeses Int      @default(60) @map("horizonte_meses")
  /// Periodicidade de EXIBIÇÃO: "mensal" | "trimestral" | "anual"
  visao          String   @default("anual")
  /// Cenário ativo (selo em todas as telas — Driver Status do CFI)
  cenarioAtivoId String?  @map("cenario_ativo_id")
  /// Análise (IBR) usada como fonte do realizado/seed, quando houver
  analysisSeedId String?  @map("analysis_seed_id")
  /// Realizado consolidado: { meses: [...], porGrupo: {receita|custos|despesas: {"YYYY-MM": n}} }
  realizado      Json?
  /// Cache do último cálculo do motor (séries, DRE, checks) + hash dos inputs
  resultadoCache Json?    @map("resultado_cache")
  /// SNAPSHOT dos índices macro (BCB Focus + PTAX) usado pelas fórmulas macro_* —
  /// gravado no modelo p/ projeção reproduzível; botão Atualizar renova + recalcula
  indicesMacro   Json?    @map("indices_macro")
  status         String   @default("Rascunho")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // ── WORKSPACE FP&A (W1, 2026-07-20) — campos ADITIVOS e anuláveis ──
  /// Envelope de produto ao qual este modelo pertence como VERSÃO (declarado;
  /// null = solto). Ver ProdutoEmpresa.
  produtoId     String? @map("produto_id")
  produtoVersao Int?    @map("produto_versao")
  /// MOTIVO DA VERSÃO (21/07/2026): por que esta versão existe — preenchido
  /// pelo "Nova versão…" (obrigatório lá); null nas versões originais.
  motivoVersao  String? @map("motivo_versao")

  blocks    ModelBlock[]
  scenarios ModelScenario[]
  produto   ProdutoEmpresa? @relation(fields: [produtoId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([produtoId])
  @@map("financial_models")
}

/// ── WORKSPACE FP&A (W1) ──────────────────────────────────────────────────────
/// PRODUTO da empresa: o ENVELOPE que acumula versões de um mesmo entregável
/// ("Orçamento 2026", "Business Plan — Sementes"). Versão é DECLARADA pelo
/// analista, nunca inferida por tipo+data (decisão de 20/07/2026 — dois
/// "Valuation 2026" podem ser trabalhos distintos, não versões).
model ProdutoEmpresa {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  /// "ibr" | "valuation" | "orcamento" | "business-plan"
  tipo      String
  /// Rótulo HÍBRIDO: prefixo do sistema + complemento livre ("Orçamento 2027",
  /// "Business Plan — Sementes"; complemento obrigatório no BP).
  rotulo    String
  /// Rótulo normalizado (sem acentos/caixa/espaços duplos) — trava anti-duplicata:
  /// colisão vira a pergunta "isto é uma nova versão de X?", nunca dois envelopes.
  rotuloNorm String @map("rotulo_norm")
  /// VIGÊNCIA (decisão de 20/07/2026): para tipo "ibr" este campo fica NULL e a
  /// vigente é DERIVADA (maior produtoVersao com status Concluída) — automática ao
  /// concluir, sem hook no fluxo do IBR. Para os demais, ponteiro MANUAL para o id
  /// do registro vigente ("vigente" é decisão de negócio).
  versaoVigenteId String?  @map("versao_vigente_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  analyses Analysis[]
  models   FinancialModel[]

  @@unique([companyId, rotuloNorm])
  @@index([companyId])
  @@map("produtos_empresa")
}

/// ── WORKSPACE FP&A (W2) ──────────────────────────────────────────────────────
/// FECHAMENTO DE PERÍODO da empresa: "fechado" é ATO (com autor e hora), nunca
/// acidente. Reabrir exige motivo e fica na trilha — prática contábil.
///
/// Os demais estados do período (aberto/recebido) são DERIVADOS dos documentos
/// (tipo+competência+cadeia de substituição que o Document JÁ tem) — este model
/// só registra o que não dá para derivar: o ato de fechar e o de reabrir.
/// Retificação pós-fechamento também é derivada: versão de documento criada
/// DEPOIS de fechadoEm ⇒ selo vermelho no workspace.
model PeriodoEmpresa {
  id        String    @id @default(uuid())
  companyId String    @map("company_id")
  /// "YYYY-MM".
  periodo   String
  /// null = nunca fechado (estado derivado); preenchido = fechado.
  fechadoEm     DateTime? @map("fechado_em")
  fechadoPorId  String?   @map("fechado_por_id")
  /// Última reabertura (o fechamento atual pode ser posterior a ela).
  reabertoEm     DateTime? @map("reaberto_em")
  reabertoPorId  String?   @map("reaberto_por_id")
  reabertoMotivo String?   @map("reaberto_motivo")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, periodo])
  @@index([companyId])
  @@map("periodos_empresa")
}

/// Bloco do modelo (schedule do CFI). Os NÓS DE DRIVER vivem em `config`
/// (edição é por bloco inteiro; trilha de auditoria registra o diff do bloco).
model ModelBlock {
  id        String   @id @default(uuid())
  modelId   String   @map("model_id")
  /// "receitas" | "custos" | "despesas" | (fases seguintes: "folha", "impostos",
  /// "capex", "giro", "divida", "dfs", "wacc", "valuation", "orcamento")
  tipo      String
  nome      String
  ordem     Int      @default(0)
  /// "simples" | "detalhado" (nível de detalhe CFI, por bloco)
  modo      String   @default("simples")
  ativo     Boolean  @default(true)
  /// { linhasReceita?: LinhaReceita[], linhasCusto?: LinhaCusto[] } — ver model-engine.ts
  config    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  model FinancialModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("model_blocks")
}

/// Cenário = overrides de params ({nodeId|linhaId: {param: valor}}). "Base" nasce
/// vazio; os demais só guardam o que diverge (cascata, sem duplicação).
model ModelScenario {
  id        String   @id @default(uuid())
  modelId   String   @map("model_id")
  nome      String
  isBase    Boolean  @default(false) @map("is_base")
  overrides Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  model FinancialModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("model_scenarios")
}
/// SNAPSHOT AUTOMÁTICO DIÁRIO (rede de segurança tipo Excel, 2026-07-21):
/// fotografia do estado EDITÁVEL de IBRs e modelos, tirada por cron 1×/dia.
/// Dedup por hash (dia sem mudança não grava); poda mantém as últimas 30
/// fotos automáticas por entidade. Restaurar é ato auditado que primeiro
/// fotografa o estado atual ("pre-restauracao") — nada se perde, nunca.
/// Sem FK para as entidades (tabela transversal): a foto de uma entidade
/// excluída é apagada pela própria poda quando sair da janela.
model SnapshotDiario {
  id         String   @id @default(uuid())
  /// "analysis" | "model"
  entidade   String
  entidadeId String   @map("entidade_id")
  /// Redundante de propósito: permite varrer/limpar por empresa sem join.
  companyId  String   @map("company_id")
  /// Estado completo fotografado (ver snapshot-diario.ts: montarConteudo*).
  conteudo   Json
  /// sha256 do conteúdo — base do dedup diário.
  hash       String
  /// "auto-diario" | "pre-restauracao" (esta última nunca é podada).
  origem     String   @default("auto-diario")
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@index([entidade, entidadeId, criadoEm])
  @@index([companyId])
  @@map("snapshots_diarios")
}
